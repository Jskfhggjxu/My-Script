-- ==================== 1. 基础服务与变量初始化 ====================
local Players = game:GetService("Players")
local uis = game:GetService("UserInputService")
local srv = game:GetService("RunService")
local workspace = game:GetService("Workspace")

local plr = Players.LocalPlayer
local mouse = plr:GetMouse()
local camera = workspace.CurrentCamera

-- 状态控制 ("Enabled" | "Disabled" | "Closed")
local joyState = "Enabled" 
local cons = {} -- 存储所有连接，用于销毁

-- 摇杆数学计算变量
local thumbstickEndX = 0
local thumbstickStartY = 0
local thumbstickSizeMultiplier = 0

local jumpStartX = 0
local jumpStartY = 0
local jumpEndX = 0
local jumpEndY = 0

local thumbstickInputObject = nil
local jumpInputObject = nil
local cameraRotateInputObject = nil
local cameraZoomInputObject = nil

local thumbstickTouchStart = Vector3.new()
local cameraZoomInputMagnitude = 0

-- 移动与视角状态变量
local isWalking = false
local jumpingInput = false
local FWmovement = 0
local RTmovement = 0

-- 视角控制变量（保留示例原版算法）
local camrotX = 0
local camrotY = 0
local cameraMoveable = true

-- ==================== 2. 屏幕区域刷新算法 ====================
local function refreshTouchRegions()
    if joyState == "Closed" then return end
    local sX = mouse.ViewSizeX
    local sY = mouse.ViewSizeY
    local isSmallScreen = math.min(sX, sY) <= 500

    -- 适配顶部保留区
    local topbarInset = game:GetService("GuiService"):GetGuiInset()
    sY = sY + topbarInset.Y

    thumbstickEndX = sX * 0.4
    thumbstickStartY = (sY + 0) * 0.333

    if isSmallScreen then
        thumbstickSizeMultiplier = 35
        jumpStartX = sX - 95
        jumpStartY = sY - 90
        jumpEndX = jumpStartX + 70
        jumpEndY = jumpStartY + 70
    else
        thumbstickSizeMultiplier = 60
        jumpStartX = sX - 170
        jumpStartY = sY - 210
        jumpEndX = jumpStartX + 120
        jumpEndY = jumpStartY + 120
    end
end

table.insert(cons, mouse:GetPropertyChangedSignal("ViewSizeX"):Connect(refreshTouchRegions))
table.insert(cons, mouse:GetPropertyChangedSignal("ViewSizeY"):Connect(refreshTouchRegions))
refreshTouchRegions()

-- ==================== 3. 触摸输入核心逻辑 ====================

-- 触摸开始
table.insert(cons, uis.TouchStarted:Connect(function(inputObject, gameProcessed)
    if joyState ~= "Enabled" then return end
    -- 如果玩家正在点聊天框或原生Roblox菜单，则不触发
    if gameProcessed then return end

    local touchPos = inputObject.Position
    local touchX = touchPos.X
    local touchY = touchPos.Y

    -- 左下角：隐形摇杆判定区
    if (not thumbstickInputObject) and touchX < thumbstickEndX and touchY > thumbstickStartY then
        thumbstickInputObject = inputObject
        thumbstickTouchStart = inputObject.Position
        isWalking = false
    -- 右下角：跳跃判定区
    elseif (not jumpInputObject) and touchY > jumpStartY and touchX > jumpStartX and touchX < jumpEndX and touchY < jumpEndY then
        jumpInputObject = inputObject
        jumpingInput = true
    -- 屏幕其余地方：视角旋转判定区（关键：这使得摇杆下碰UI时，这里不冲突）
    elseif not cameraRotateInputObject then
        cameraRotateInputObject = inputObject
    else
        cameraZoomInputObject = inputObject
        cameraZoomInputMagnitude = (cameraRotateInputObject.Position - cameraZoomInputObject.Position).Magnitude
    end
end))

-- 触摸移动
table.insert(cons, uis.TouchMoved:Connect(function(inputObject)
    if joyState ~= "Enabled" then return end
    
    local touchPos = inputObject.Position
    local touchX = touchPos.X
    local touchY = touchPos.Y
    
    if inputObject == thumbstickInputObject then
        local direction = inputObject.Position - thumbstickTouchStart
        local directionMag = direction.Magnitude / thumbstickSizeMultiplier
        if directionMag > 0.05 then
            isWalking = true
            direction = direction.Unit * math.min(1, (directionMag - 0.05) / 0.95) 
            FWmovement = -direction.Y
            RTmovement = direction.X
        else
            isWalking = false
        end
    elseif inputObject == jumpInputObject then
        jumpingInput = touchY > jumpStartY and touchX > jumpStartX and touchX < jumpEndX and touchY < jumpEndY
    else
        -- 双指缩放视角
        if cameraZoomInputObject then
            local newMagnitude = (cameraRotateInputObject.Position - cameraZoomInputObject.Position).Magnitude
            -- 原脚本视角缩放算法...
            cameraZoomInputMagnitude = newMagnitude
        -- 单指划动旋转视角
        elseif (inputObject == cameraRotateInputObject) and cameraMoveable then
            local rotation = uis:GetMouseDelta()
            camrotX = math.clamp((rotation.Y * -0.005) + camrotX, -math.pi/2, math.pi/2)
            camrotY = (rotation.X * -0.005) + camrotY
            
            -- 将视角应用到当前相机上
            camera.CFrame = CFrame.new(camera.CFrame.Position) * CFrame.Angles(0, camrotY, 0) * CFrame.Angles(camrotX, 0, 0)
        end
    end
end))

-- 触摸结束
table.insert(cons, uis.TouchEnded:Connect(function(inputObject)
    if inputObject == thumbstickInputObject then
        thumbstickInputObject = nil
        isWalking = false
        FWmovement = 0
        RTmovement = 0
    elseif inputObject == jumpInputObject then
        jumpInputObject = nil
        jumpingInput = false
    elseif inputObject == cameraRotateInputObject then
        cameraRotateInputObject = nil
        cameraZoomInputObject = nil
    elseif inputObject == cameraZoomInputObject then
        cameraZoomInputObject = nil
    end
end))

-- ==================== 4. 驱动真实角色移动与跳跃 ====================
table.insert(cons, srv.Heartbeat:Connect(function()
    if joyState ~= "Enabled" then return end
    
    local char = plr.Character
    if char and char:FindFirstChild("Humanoid") then
        local humanoid = char.Humanoid
        
        -- 跳跃控制
        if jumpingInput then
            humanoid.Jump = true
        end
        
        -- 移动控制：将屏幕相对移动，转化为基于相机视角的绝对世界移动向量
        if isWalking then
            local camCF = camera.CFrame
            -- 提取相机的水平向前和向右向量（忽略Y轴倾斜，防止走入地下或飞天）
            local forward = Vector3.new(camCF.LookVector.X, 0, camCF.LookVector.Z).Unit
            local right = Vector3.new(camCF.RightVector.X, 0, camCF.RightVector.Z).Unit
            
            -- 计算最终世界移动方向
            local moveDirection = (forward * FWmovement) + (right * RTmovement)
            
            -- 驱动真实角色
            humanoid:Move(moveDirection, false)
        else
            -- 停止时清除移动输入
            humanoid:Move(Vector3.new(), false)
        end
    end
end))

-- ==================== 5. 聊天指令逻辑 (-DisableJoy, -EnableJoy, -CloseJoy) ====================
local function onChatted(msg)
    local lowerMsg = string.lower(msg)
    
    if lowerMsg == "-disablejoy" then
        if joyState == "Closed" then return end
        joyState = "Disabled"
        isWalking = false
        jumpingInput = false
        thumbstickInputObject = nil
        jumpInputObject = nil
        -- 让角色瞬间停下
        if plr.Character and plr.Character:FindFirstChild("Humanoid") then
            plr.Character.Humanoid:Move(Vector3.new(), false)
        end
        
    elseif lowerMsg == "-enablejoy" then
        if joyState == "Closed" then return end
        joyState = "Enabled"
        
    elseif lowerMsg == "-closejoy" then
        joyState = "Closed"
        -- 彻底销毁所有监听事件
        for _, connection in ipairs(cons) do
            if connection then connection:Disconnect() end
        end
        cons = {}
        -- 释放所有输入对象引用
        thumbstickInputObject = nil
        jumpInputObject = nil
        cameraRotateInputObject = nil
        cameraZoomInputObject = nil
    end
end

table.insert(cons, plr.Chatted:Connect(onChatted))
